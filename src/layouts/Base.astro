---
import '../styles/global.css';
const { title = 'Michalina Sablik' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Michalina Sablik — Art historian, curator of exhibitions and public programs">
  <title>{title}</title>
  <link rel="icon" type="image/x-icon" href="/favicon.ico">
</head>
<body>
  <header class="site-header">
    <div class="container">
      <div class="site-title"><a href="/">Michalina Sablik</a></div>
      <button class="menu-toggle" onclick="document.querySelector('.primary-nav').classList.toggle('open')">☰</button>
      <ul class="primary-nav">
        <li><a href="/news/">News</a></li>
        <li><a href="/writtings/">Writtings</a></li>
        <li><a href="/exhibitions/">Exhibitions</a></li>
        <li><a href="/about/">About</a></li>
      </ul>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-content">
        <p>&copy; {new Date().getFullYear()} Michalina Sablik</p>
        <ul class="social-links">
          <li><a href="https://www.instagram.com/miska_sablik/" target="_blank">Instagram</a></li>
          <li><a href="https://wa.me/+48531204498" target="_blank">WhatsApp</a></li>
          <li><a href="https://www.linkedin.com/in/michalina-sablik-3a35a161/" target="_blank">LinkedIn</a></li>
        </ul>
      </div>
    </div>
  </footer>
</body>
</html>
