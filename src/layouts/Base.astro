---
import '../styles/global.css';
const SITE_URL = 'https://michalinasablik.com';
const { title = 'Michalina Sablik' } = Astro.props;
const description = 'Michalina Sablik — Art historian, curator of exhibitions and public programs';
const canonicalURL = new URL(Astro.url.pathname, SITE_URL).href;
const socialImage = new URL('/images/og-image.jpg', SITE_URL).href;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <title>{title}</title>
  <link rel="canonical" href={canonicalURL}>
  <link rel="icon" type="image/png" href="/favicon-32.png">
  <link rel="apple-touch-icon" href="/favicon-180.png">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="Michalina Sablik">
  <meta property="og:url" content={canonicalURL}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={socialImage}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="Michalina Sablik — Art historian & curator">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={socialImage}>
</head>
<body>
  <header class="site-header">
    <div class="container">
      <div class="site-title"><a href="/" aria-label="Michalina Sablik — Art Consulting"><img src="/images/logo-michalina-sablik.jpg" alt="Michalina Sablik — Art Consulting" style="height:46px;width:auto;display:block;" /></a></div>
      <button class="menu-toggle" onclick="document.querySelector('.primary-nav').classList.toggle('open')">☰</button>
      <ul class="primary-nav">
        <li><a href="/news/">News</a></li>
        <li><a href="/exhibitions/">Exhibitions</a></li>
        <li><a href="/about/">About</a></li>
      </ul>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-content">
        <p>&copy; {new Date().getFullYear()} Michalina Sablik</p>
        <ul class="social-links">
          <li><a href="https://www.instagram.com/miska_sablik/" target="_blank">Instagram</a></li>
          <li><a href="https://wa.me/+48531204498" target="_blank">WhatsApp</a></li>
          <li><a href="https://www.linkedin.com/in/michalina-sablik-3a35a161/" target="_blank">LinkedIn</a></li>
        </ul>
      </div>
    </div>
  </footer>
</body>
</html>
