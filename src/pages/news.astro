---
import Base from '../layouts/Base.astro';

const news = [
  { title: "Ask me anything. WetMeWild", details: "Barcelona: RARO On-Site Projects | 29 May – 19 June 2026", text: "WetMeWild hacks this field, disrupting comfortable equilibrium and drawing attention to the social as well as environmental costs of AI revolution. An avatar and AI assistant created by visual artist Justyna Górowska. The fictional character has been developed across various projects since 2017 as a fluid, hybrid interpretation of a mythical figure from Slavic mythology, a sex worker, and a Corpo-Shiva. In her previous works — including AR applications, performances, photography, and video — the artist has explored themes of water contamination, ecosexuality, and hydrofeminism. The digital avatar created for this project, based on a 3D scan of the artist herself, is the latest immersive iteration of the project. In an intimate room designed for the purpose, visitors can speak with her in real time in three languages — English, Spanish, and Catalan.", link: "", year: 2026, tags: ["Exhibition"] },
  { title: "A Non-Player Character: Interview with Laureta Hajrullahu", text: "New interview out in MOST Magazine! I sat down with Laureta Hajrullahu to talk about her exhibition \"to undo, to crumble, to vanish\" at the National Gallery of Kosovo, which I curated. We discussed how growing up on the Kosovo-Serbia-North Macedonia borderlands while being immersed in early internet culture shaped her artistic practice. Laureta explores the evolution of digital identity, the shift from experimental online spaces to algorithmically controlled environments, and how video games reproduce cultural hierarchies. Her video installations and textile works employ early web aesthetics and metaphors of entrapment, drawing parallels between digital constraints and geopolitical limbo.", link: "https://mostmagazine.org/2026/04/20/a-non-player-character-interview-with-laureta-hajrullahu/", year: 2026, tags: ["Interview", "Publication"] },
  { title: "Permitted Vulnerability: Gvantsa Jishkariani in Barcelona", details: "Barcelona: Espai Souvenir | May 5 – May 30, 2026 | Opening: May 5, 7:00 PM", text: "I am thrilled to present the first solo exhibition in Spain of Georgian artist Gvantsa Jishkariani. In \"Permitted Vulnerability\", Jishkariani presents a series of textile works based on decorative tapestries that she tears apart and reconstructs, adding embroidered slogans drawn from political protest, popular culture, and academic language. Her practice — uncompromising, funny, and deliberately disruptive — generates tension and exposes the contradictions embedded in both language and social reality. This is a gesture of reclaiming control: taking hold of the very topics and aesthetics that once shaped her, and reshaping them through her own hands.", link: "/exhibitions/permitted-vulnerability/", year: 2026, tags: ["Exhibition"] },
  { title: "The War Over Guernica: How a Famous Painting Divides Spain", text: "I've written a piece about the cultural and political \"civil war\" raging in Spain around Pablo Picasso's Guernica. Dive in at MINT Magazine!\nIn Spain — one of the most pacifist countries in Europe, which recently stood up against Trump — an internal war has erupted. Its hostage is Guernica, a masterpiece of avant-garde painting. Pablo Picasso painted this monumental work in 1937 as a protest against the civil war that broke out between left-wing republicans and a right-wing coalition, backed by Hitler's German forces and Italian fascist air power.", link: "https://mintmagazine.pl/artykuly/wojna-o-guernice-jak-slynny-obraz-dzieli-hiszpanow", year: 2026, tags: ["Publication"] },
  { title: "Seeds of Planted Ideas: On the Practice of Liliana Zeic", text: "New text out on Moodaily from Mood Scent Bar! This time on the practice of Liliana Zeic, a Warsaw-based artist.\nIn her work, wood grain becomes a language for queerness, marginality, and the politics of botanical \"otherness\" — from the demonized women of Mickiewicz's ballads transformed into lake lobelia, to slowly vanishing Baltic bladderwrack. A craft historically dismissed as ornament, repurposed as critical tool.\nI've been thinking about her practice for a while: the way slowness and material resistance can do what screens no longer can.", link: "https://moodscentbar.com/en/moodaily/post/268_ziarna-zasadzonych-idei-o-tworczosci-liliany-zeic", year: 2026, tags: ["Publication"] },
  { title: "Hydrosex Call: Justyna Górowska as the AI Water Nymph WetMeWild", details: "Zagreb: Pogon Jedinstvo | April 23, 2026, 7:00 PM", text: "A performance and interactive virtual space in which two protagonists meet: the artist Justyna Górowska, travelling from Poland for the occasion, and her digital alter ego WetMeWild — a Slavic water nymph, sex worker, and AI-based avatar developed since 2017. In the underwater VR environment designed for the character, participants can engage in real-time conversation with WetMeWild on topics ranging from microplastic pollution to biodiversity loss and the ecological cost of AI infrastructure. The project is part of KUĆĆA's curatorial programme, which I have been developing together with Klara Petrović and Luja Šimunović. It is supported by the Adam Mickiewicz Institute and Zarodny Kultura.", link: "", year: 2026, tags: ["Performance", "Exhibition"] },
  { title: "Circassian Beauty Performance by Elif Satanaya Özbay in Warsaw", details: "Warsaw: Museum of Modern Art | April 10, 7:30 PM | part of \"City of Women\" public program", text: "In her performance Elif Satanaya Özbay examines the construction of the \"Circassian Beauty,\" a 19th-century spectacle popularized in P. T. Barnum's exhibitions. Marketed as exotic refugees, these staged women embodied fantasies of purity, captivity, and otherness. Accompanied by live accordion, the performance unfolds as both lecture and incantation. Curators: Vera Zalutskaya, Michalina Sablik", link: "https://artmuseum.pl/en/events/circassian-beauty-performance-by-elif-ozbay", year: 2026, tags: ["Performance"] },
  { title: "Book Launch of Liliana Zeic's Monograph in Warsaw", details: "Warsaw: Museum of Modern Art | March 24, 6:00 PM | Liliana Zeic, Piotr Lisowski. Moderated by Michalina Sablik", text: "This is the first publication of such scope to examine the work of one of the most compelling artists of the younger generation. It combines critical essays with rich visual material, a chronology, and a bibliography. It demonstrates how Zeic's work intertwines reflections on gender identity and sexuality with nature studies, and how art can become a tool for dialogue and meaningful social change.", link: "https://artmuseum.pl/wydarzenia/ksiazka-w-muzeum-premiera-monografii-liliany-zeic?term=019caee9-611b-7375-b739-092d406a9282", year: 2026, tags: ["Publication"] },
  { title: "Exhibition at the National Gallery of Kosovo", text: "Laureta Hajrullahu's first solo exhibition at the National Gallery of Kosovo explores identity and digital spaces, where games, algorithms, and internet culture intersect with physical objects and immersive video works commissioned for this exhibition. In her practice, Laureta draws on speculation, digital folklore, and the emotional residues of online life, approaching identity as an entity that is constantly edited and redefined. She addresses questions of privacy, gender, and online identity, as well as themes related to a post-internet future in which boundaries are increasingly fluid.", link: "https://www.galeriakombetare-rks.com/en/ekspozitat", year: 2026, tags: ["Exhibition"] },
  { title: "Artysta Zawodowiec: The ING Polish Art Foundation", text: "This year, I'm happy to join the Artysta – Zawodowiec program as a lecturer and portfolio consultant, working with young and emerging artists at the beginning of their professional paths. On March 19th, I will give a lecture on how to take your first steps internationally — focusing on grants, exchange programs, and practical tips drawn from my curatorial practice and personal experience of living and working in migration.", link: "https://ingart.pl/pl/az/news/a_z_10", year: 2026, tags: ["Lecture"] },
  { title: "Cura: Lecture at the Grid in Gdańsk", details: "Gdańsk: Grid | February 12, 2026, 6:00 PM", text: "What does it mean to make one's debut in the art world? Can an artist have more than one debut? Is a debut a biographical moment, an institutional construct, or perhaps a tool of power regulating access to visibility, resources and prestige? This lecture is devoted to the category of debut as one of the key, yet least problematised mechanisms in the field of art. I examine the role of galleries, museums, competitions, open calls and residencies in constructing artistic biographies and normative trajectories of 'success'. Drawing on over eight years of experience working with so-called 'young artists,' the lecture discusses strategies of conscious curating, including working with artistic biographies, mediating between artists and institutions, and critically reflecting on the mechanisms of inclusion and exclusion in the field of art.", link: "https://gridarthub.pl/event/27", year: 2026, tags: ["Lecture"] },
  { title: "Upcoming Art Events and Festivals in 2026", text: "For myself and for you, I did a bit of research into international events worth marking in the calendar for 2026. Enjoy!", link: "https://moodscentbar.com/pl/moodaily/post/262_najlepsze-wystawy-i-festiwale-sztuki-w-2026-roku", year: 2026, tags: ["Publication"] },
  { title: "New Book by Anna Raczyńska", text: "\"Old Habits, New Beginnings\" is a solo publication by Anna Raczyńska, a 200+ page, dual-sided Polish–German catalogue with two covers and a central English section. Reflecting the transdisciplinary nature of her practice from past 10 years. Featuring 178 photographs from projects across Europe, with essays by Michalina Sablik and Sophia Scherer, and graphic design by Karolina Pietrzyk and Tobias Wenig. In January 2025 join the promotional event at KVOST Berlin.", link: "http://annasteinherz.com/publications/", year: 2025, tags: ["Publication"] },
  { title: "The City of Women", text: "The City of Women is an exhibition consisting of four parts: Gutsy, curated by Julia Bryan-Wilson, Other Tomorrows by Michalina Sablik and Vera Zalutskaya, Her Heart by Karolina Gembara, and We were there. International Women's Year 1975, curated by Wiktoria Szczupacka. This mosaic of different attitudes and aesthetics is a testament to the richness, diverse traditions and power of feminist art, which will be presented in parallel to the historic, monumental exhibition The Female Question 1550–2025.", link: "https://artmuseum.pl/en/exhibitions/the-city-of-women", year: 2025, tags: ["Exhibition"] },
  { title: "Self-Portrait with Tongue Out: Book by Paulina Stasik", text: "It's here! The book Self-Portrait with Tongue Out is now available — the first artist's book collecting reproductions of Paulina Stasik's works from the past five years, interwoven with her own commentaries and two critical essays. Natalia Gierowska examines how the painter draws on myths and folk tales and the female figures within them. My text situates Stasik's practice within the wounds of women's writing as described by Hélène Cixous. I also had the pleasure of editing the book. The book was designed by Agata Biskup and published by BWA Tarnów.", link: "https://www.bwa.tarnow.pl", year: 2025, tags: ["Publication"] },
  { title: "A New Exhibition by Paulina Stasik", text: "The paintings of Paulina Stasik, a Kraków-based artist, although at first glance full of allegories and symbols, are deeply rooted in her autobiography. Together, they form an intimate—though camouflaged—self-portrait unfolding over time. Her latest canvases and pastels on paper will be on view at the Biuro Wystaw Artystycznych in Tarnów starting October 19. I am grateful to have accompanied the artist during this important moment of transformation. The exhibition will be accompanied by the launch of the first comprehensive book on her practice, \"Self-Portrait with Tongue Sticking Out\", designed by Agata Biskup and featuring the artist's own commentaries as well as critical texts by Natalia Gierowska and myself.", link: "https://www.facebook.com/events/826392516725762/", year: 2025, tags: ["Exhibition"] },
  { title: "Launching Curated Walks in Barcelona", text: "This autumn join me for a relaxed series of three art walks through Barcelona, where we explore the city's vibrant contemporary art scene. From major institutions and private galleries to key art events, each walk offers a unique insight into the latest artistic trends. No specialist knowledge is required—these walks are perfect for beginners and art enthusiasts alike. Each tour is guided by an experienced art curator, supporting and accompanying Michalina Sablik, ensuring a rich and engaging experience. After the walk, we'll gather for a casual drink to discuss what we've seen, share impressions, and enjoy the city's creative atmosphere together.", link: "https://luma.com/user/usr-iJcSm302I4zjTWB", year: 2025, tags: ["Lecture"] },
  { title: "Catalogue Is Out!", text: "The catalogue for the exhibition \"Swarożyce. Contemporary Woman's* Metalwork\" is now available, designed by Karolina Pietrzyk and Tobi Wenig. It includes the following texts: \"Swarożyce. Emancipation and Women's* Metalwork\" – a curatorial text by Magdalena Lazar and Michalina Sablik; \"Reclaiming the Myth\" by Aleksandra Skowrońska – an essay on the potential of myth as a tool for cultural critique and building alternative narratives; \"Female Elements\" by Zofia Małysa-Janczy – a history of women working with metal: from mythological representations, through industrial labor and the Bauhaus era, to contemporary artistic strategies; \"Phenomena\" by Weronika Wysocka – a short story complementing her artwork presented in the exhibition.", link: "https://ksiegarnia.rzezba-oronsko.pl/product_info.php?products_id=266", year: 2025, tags: ["Publication"] },
  { title: "Interview for MiejMiejsce.pl", text: "Raised on theory, grown in practice – Michalina Sablik has been working as a curator, critic, and art researcher for years, building her career from grassroots initiatives to collaborations with the largest institutions in the country. In conversation with Gabi Skrzypczak, she talks about the relational side of curating, the power of collectivity, balancing activism and storytelling, and why she is more interested today not in identities, but in their hybrids and alternatives.", link: "https://miejmiejsce.com/sztuka/jak-robic-wystawy-w-czasach-polikryzysu", year: 2025, tags: ["Interview"] },
  { title: "Slime. Joanna Fluder", details: "Warsaw: Zachęta – National Gallery of Art | July 24 – October 19, 2025", text: "The Slime exhibition presents a selection of 140 recent gouaches on paper or canvas, and premiere installations created especially for the space of Zachęta. Joanna Fluder has developed her own artistic language that combines surrealism, personal mythology, humour, and a vivid imagination. In her works, she talks about women's everyday experiences, motherhood, neurodivergence, creative work, the social role of care, and the relationship with the surroundings, especially nature.", link: "https://zacheta.art.pl/en/wystawy/joanna-fluder-sluz", year: 2025, tags: ["Exhibition"] },
  { title: "Soft Smiths. Contemporary Women's* Metalwork", details: "Orońsko: Centre of Polish Sculpture | July 5 – August 24, 2025", text: "Curators: Michalina Sablik, Magdalena Lazar. Artists: Michalina Bigaj, Hannah Sophie Dunkelberg, Agata Ingarden, Lito Kattou, Magdalena Lazar, Lucia Leuci, Markéta Magidová, Ola Nenko, Emma Passera, Ala Savashevich, Weronika Wysocka.", link: "", year: 2025, tags: ["Exhibition"] },
  { title: "Collaboration with AWARE", text: "Recently I have wrote a biogram of Urszula Broll, a key figure in the Katowice underground scene for AWARE : Archives of Women Artists, Research & Exhibitions where you can find profiles of many women and non-binary artists active from the 17th century to the present day, representing diverse cultural contexts. The project is being developed collectively, incorporating contributions from researchers across various countries. Check out the French portal to discover more astonishing women artists.", link: "https://awarewomenartists.com/en/artiste/urszula-broll/", year: 2025, tags: ["Publication"] },
  { title: "Identity Crisis Network Announces Program for the Intentional Conference in Zagreb", text: "We are extremely proud and happy to announce the full program of the conference in the Museum of Modern Art in Zagreb that will take place on the 23rd and 24th of May 2025. Following the open call, we have invited 20 scholars, curators, artists, and other individuals and collectives to join in the conversation that seeks to challenge established notions of identity and subjectivity in contemporary art and culture. The event is open to all the audiences, but remember to register first!", link: "https://identitycrisisnetwork.com/conference-2025/", year: 2025, tags: ["Lecture"] },
  { title: "Hyperlocality: Personal Cartographies", text: "To anyone in Barcelona – you're warmly invited to the group exhibition at CasCaDas ArtSpace, opening on May 15th! The exhibition, Hyperlocality: Personal Cartographies, is an attempt at grounding. In an era of constant mobility, remote work, migration, and being \"in between,\" the (international but) Barcelona-based artists participating in this project turn their gaze toward what is close, tangible, and local. They trace connections to their everyday surroundings, document the movement of their bodies through space, and create personal maps and geographies. The exhibition emerged in response to an open call, where artists shared their own interpretations of the idea of hyperlocality.", link: "https://fb.me/e/5wjXuq3Ri", year: 2025, tags: ["Exhibition"] },
  { title: "Mammals and Suckers: An Exhibition by Ida Karkoszka and Karolina Wysocka", details: "Warsaw: Galeria HOS | April 4 – May 31, 2025", text: "The exhibition Mammals and Suckers is a dialogue between Ida Karkoszka and Karolina Wysocka, two visual artists united by their engagement with socio-ecological issues and their critical approach to sculptural material. Curator: Michalina Sablik.", link: "https://www.facebook.com/events/563773252677138/", year: 2025, tags: ["Exhibition"] },
  { title: "Justyna Smoleń's Catalog", text: "The catalog for the exhibition Fragile Dreams by Justyna Smoleń has just been released, featuring texts by Olga Drenda and Ewa Borysewicz, as well as an interview with the artist conducted by me. We invite you to the book launch, which will be hosted by Katarzyna Wąs on April 1st at the Bunkier Sztuki Gallery in Kraków.", link: "https://bunkier.art.pl/exhibition/justyna-smolen-kruche-sny/", year: 2025, tags: ["Publication"] },
  { title: "Exhibition Open Call: Hyperlocality", text: "CasCaDas ArtSpace invites artists to submit works for an open call for an exhibition in Barcelona. We are particularly interested in micro-histories that engage with specific communities, their history, architecture, or identity, as well as works that explore the relationship between locality and globality (glocal). Together, we will explore how changes in place affect artistic practice. How does being \"an outsider\" impact perspective and perception of a new place? How are local contexts transferred by artists into new locations? How do artists address \"being in-between\"? How does being a digital native affect this situation? How is the definition of place and authenticity evolving? Apply by filling the Google Form until 21st of March 2025.", link: "https://www.cascadasartspace.com/open-calls-2025", year: 2025, tags: ["Exhibition"] },
  { title: "Text for Edyta Hul's Catalog", text: "I wrote a text titled The Wild, the Dirty, and the Repressed: The Paintings of Edyta Hul for the catalog accompanying the exhibition Something's in the Water by Edyta Hul at Galeria Bielska BWA in Bielsko-Biała. The book is available in the gallery!", link: "https://galeriabielska.pl/wystawa/edyta-hul-cos-jest-w-wodzie", year: 2025, tags: ["Publication"] },
  { title: "Open Call Alert: International Conference in Zagreb", text: "Submissions are now open for presentation proposals at the upcoming conference at the Museum of Contemporary Art in Zagreb! We invite researchers, curators, artists, and collectives to participate in this forum dedicated to exploring contemporary understandings of identity and subjectivity in art. Venue: Museum of Contemporary Art, Zagreb, Croatia. Dates: May 23–24, 2025. Submission Deadline: February 28, 2025. This project is supported by the Adam Mickiewicz Institute as part of the international cultural program of Poland's presidency of the Council of the European Union in 2025.", link: "https://identitycrisisnetwork.com/conference/", year: 2025, tags: ["Lecture"] },
  { title: "New Exhibition in Krakow!", text: "I'm returning to familiar grounds—back to Kraków, a city that's always in my heart. This time, it's thanks to Justyna Smoleń, who invited me to accompany her in the preparations for her major solo exhibition, \"Fragile Dreams\". The show will feature objects and installations (including several premiere works created specifically for the Galeria Sztuki Współczesnej Bunkier Sztuki) crafted using collage and ceramic techniques. The exhibition will be accompanied by a catalog with texts by Olga Brenda, Ewa Borysewicz, and myself. A heartfelt thank you in advance to everyone involved in the process, especially Delfina Jałowik, Agnieszka Mazoń-Żywolewska, Renata Motyka, Michał Sroka, Bartek Buczek, and Ola Nenko. Join us for the opening on January 29th!", link: "https://bunkier.art.pl/exhibition/justyna-smolen-kruche-sny/", year: 2025, tags: ["Exhibition"] },
  { title: "Interview for Culture.pl About Identity Crisis Network", text: "'Western civilisation is stuck in a crisis of imagination, few people can afford to use fantasy, we rarely think about the future of people and the planet in positive terms. We would like at some stage of the project to move away from making diagnoses to imagining inspiring ways of coexisting in the world.' On the crisis of identity politics (from left to right), the problems of institutions and curation, and faith in artistic intelligence. In a conversation for Culture.pl with Vera Zalutskaya, we talk about the Identity Crisis Network project. For now, we mainly have questions and concerns to share in a series of six seminars – two more to go, so feel free to join us next week.", link: "https://culture.pl/pl/artykul/vera-zalutskaya-michalina-sablik-tozsamosc-stala-sie-narzedziem-w-politycznych-walkach-wywiad", year: 2025, tags: ["Interview"] },
  { title: "Notes on 15. Manifesta Biennale", text: "The new article about 15. Manifesta Biennial in Barcelona Metropolitana has just been published in Moodaily. I have picked 4 of many amazing locations and the works placed there that enter into a dialogue with the space and its contexts.", link: "https://moodscentbar.com/pl/moodaily/post/221_manifesta-2024-na-peryferiach-barcelony", year: 2024, tags: ["Publication"] },
  { title: "Identity Crisis Network", text: "Since the beginning of the year I have been working in a (for the first time so large and international!) curatorial collective with Vera Zalutskaya, Luka Cvetkovic, Luja Šimunović & Klara Petrović (from KUĆĆA) on a major project focusing on the search for new artistic practices in Eastern Europe in response to the crisis of identity politics. In a few weeks we will announce a programme of online seminars, to which we are inviting great professionals from the field of art, philosophy or social sciences. Next year we are organising a conference in Zagreb. Also linked to this project are our study visits to North Macedonia, Moldova, Albania or Kosovo, which you can follow on IG. Join the newsletter!", link: "https://identitycrisisnetwork.com", year: 2024, tags: ["Lecture"] },
  { title: "A Man Eating His Own Tail: Exhibition by Przemek Branas", details: "Barcelona: CasCaDas ArtSpace | September 26 – November 2, 2024", text: "In the latest installation, \"A Man Eating His Own Tail,\" Przemek Branas references the transcultural mythical figure of the Ouroboros. Associated with solar cults, the serpent became a symbol of infinity, eternal return, and the cyclical nature of time. This constantly devouring and regenerating mythical creature represented the eternity of matter and the concept of reconciling apparent opposites. However, it was also sometimes interpreted as a symbol of foolishness, going in circles, or irrational behavior. Curator: Michalina Sablik. Organizers: CasCaDas ArtSpace, Instytut Adama Mickiewicza. Partners: Krupa Art Foundation.", link: "https://www.facebook.com/events/1663407687778297", year: 2024, tags: ["Exhibition"] },
  { title: "Lecture for Culture Makes: Decolonialism in Art Institutions", text: "Starting from the theme of this year's Venice Art Biennale, 'Foreigners are everywhere', we looked at the decolonial practices. These are based on the inclusion of marginal and overlooked voices, the reinterpretation of existing works, and the revision of gallery or museum practices. This trend is also reflected locally – in Polish art, where artists reveal power relations resulting from geopolitical processes and include national, ethnic or class minorities, and in Belarusian and Ukrainian art, which draws attention to Russian colonialism.", link: "https://www.youtube.com/watch?v=gMLMEEswozk&t=2947s", year: 2024, tags: ["Lecture"] },
  { title: "We Are a Dream: Exhibition in Leipzig", text: "At the beginning of September we are opening with Aleksandra Liput her solo exhibition at Kunsthalle.Ost in Leipzig! In her solo exhibition, Aleksandra Liput refers to Ursula Le Guin's science-fiction book 'The Lathe of Heaven'. The plot of the book takes place in a violent, retrofuturistic dark city in a dystopian world, which in many ways resembles the reality we live in during the 2020s. The world around the protagonist is like a dark dream. All the movements of the grey people are recorded by technological surveillance, and their bodies are constantly subjected to the effects of various drugs. The protagonist discovers that even the realm of dreams is no longer safe and worry-free and that his disturbing fantasies are coming true in reality. So he decides to stay awake for months and undergo treatment from a suspicious doctor. He wants to reclaim his sleep, which for him is one of the last outposts of rebellion and individual freedom.", link: "https://fb.me/e/5h2KSQtrr", year: 2024, tags: ["Exhibition"] },
  { title: "Smelling Art. Artists in the World of Fragrances", text: "In recent years there has been a growing interest among visual artists in the sense of smell, including the creation of scents and perfumes. Many of them deal with the sense of smell in their creative practice, think about the olfactory layer of their works and create installations that affect other senses than just the sense of sight. Moreover, they often compose their own fragrances as part of their artistic activity and even create original perfumery. Through scent, they talk about people's relationship with the world and with nature, about emotions and memory.", link: "https://moodscentbar.com/pl/moodaily/post/208_poczuc-sztuke-artysci-i-artystki-w-swiecie-zapachow", year: 2024, tags: ["Publication"] },
  { title: "Hybrids. Trans-corporeal Performances at the Labyrinth Gallery in Lublin in the 1970s", text: "The latest magazine Sešitu pro umění, teorii a příbuzné zóny 36/2024 (The Notebook for Art, Theory and Related Zones) published by the Academy of Fine Arts in Prague features my text on trans-corporeal performances in the 1970s. In it, I look at the work of Teresa Murak, Krzysztof Zarębski, Tomek Kawiak and Józef Robakowski in terms of their complex relationship with non-human entities. The article is only a part of my PhD research, which is dedicated to performance at the Labirynt Gallery and BWA Lublin.", link: "https://vvp.avu.cz/sesit/sesit-36/", year: 2024, tags: ["Publication"] },
  { title: "Herbalists. Teresa Murak and Her Daughters", text: "For the latest issue of Kwartalik Rzeźby Orońsko I have written an article \"Herbalists. Teresa Murak and her Daughters\" in which I look at the collaborative creative process engaging plants covering works by Diana Lelonek, Weronika Zalewska, Pamela Bożek and Julia Krupa, among others.", link: "https://ksiegarnia.rzezba-oronsko.pl/index.php?view=all&cPath=1", year: 2024, tags: ["Publication"] },
  { title: "Art Guide to Barcelona", text: "I would like to remind you that the Manifesta Biennial is about to open in Barcelona, or rather on its outskirts, and it is already worth buying tickets for September 2024. To mark the occasion, I have prepared a micro guide to contemporary art in the city for MOOD SCENT BAR. I invite you to follow the paths I'm slowly trodding. No Antonio Gaudi included.", link: "https://moodscentbar.com/pl/moodaily/post/190_barcelona-przewodnik-po-muzeach-i-galeriach-sztuki-wspolczesnej", year: 2024, tags: ["Publication"] },
  { title: "Interview with Jakub Gliński", text: "For PURO Hotels Mag, I talk to Jakub Glinski, with whom we did our first exhibition as the duo Dzidy in 2018. Today, he candidly tells me about his unusual creative process, ADHD and his journey from the hardcore club scene and performance to the gallery world.", link: "https://purohotel.pl/en/puro-mag/jakub-glinski/", year: 2024, tags: ["Interview"] },
  { title: "Public Programs for \"From the Ashes\" Exhibition", text: "The \"From the Ashes\" exhibition at Zachęta National Gallery of Art is accompanied by a public program combining educational activities for various groups, author tours, workshops (including AI), performances and concerts. Among the artists involved in the program are Antonina Nowacka, Planet Luz, the X-Philes collective, Agata Lankamer and One Vivid Orange Wall.", link: "https://zacheta.art.pl/pl/wystawy/z-popiolow", year: 2024, tags: ["Lecture", "Performance"] },
  { title: "\"Call to Action!\" Podcast in Vogue Polska", text: "The protagonists of the podcast \"Call To Action!\" by Zuzanna Krzątała are two curators, Michalina Sablik and Aleksandra Skowronska, whose interdisciplinary exhibitions marked the beginning of a new opening at Zachęta. Reflections on the future, especially in the context of the impending climate catastrophe, become the basis for reflexions on new directions in art. The boundaries between technology and biology, machine and human and animal are blurring. Through interactive objects, Michalina and Aleksandra invite us on a journey that engages the senses and imagination.", link: "https://www.vogue.pl/a/podcast-call-to-action-s-5-odc-1-sztuka-nieobojetnosci-nowe-otwarcie-zachety", year: 2024, tags: ["Interview"] },
  { title: "Magazyn Zachęta Online", text: "Aleksandra Skowronska and I had the pleasure of editing No. 39 of the Zachęta Online Magazine accompanying our exhibitions. They invited writers, academics, researchers and artists to share their reflections on breakthrough moments and accompanying postulates and observations on the speculative turn in art, cyborg knowledge, the visuality of climate catastrophe or allied perspectives.", link: "https://zacheta.art.pl/magazyn/en/", year: 2024, tags: ["Publication"] },
  { title: "Artsy Malaga", text: "Andalusia and Costa del Sol, loosely translated as the Sunny Coast, are one of the most popular travel destinations. With over 300 sunny days a year, a very short winter, the sea, mountains, and beautiful Moorish monuments, they attract tourists not only during the holiday season. However, few know that it's also a hub of contemporary art and a region where numerous artists create on a daily basis. Discover the most interesting museums, galleries, and lesser-known art spots in Malaga, a city where I lived for three months.", link: "https://moodscentbar.com/pl/moodaily/post/179_artystyczna-malaga", year: 2024, tags: ["Publication"] },
  { title: "From the Ashes Exhibition", text: "I'm currently testing myself in the role of a curator for special tasks, preparing an exhibition for Zachęta National Gallery of Art in Warsaw at an express pace. I'm very excited to finally reveal what I've been working on lately. I'm thrilled that on March 15th, we are opening the \"From the Ashes\" exhibition, which showcases works by young artists created after 2020 in response to experiencing a continuous crisis of ecology, economy, and socio-politics. Drawing on the mythical figure of the phoenix allows for a metaphorical narrative of experiencing the \"burning world\" and exploring new ideas for the world's regeneration, born in moments of deep despair. Artists: Hanna Antonsson, Sara Bezovšek, Justyna Górowska, Ewelina Jarosz, Marcin Janusz, Karolina Jarzębak, Ida Karkoszka, Agata Lankamer, Aleksandra Liput, Julia Lohmann, Antonina Nowacka, szkoda (Kasia Piątkowska), Aleksandra Wieliczko, Klara Woźniak, Xphiles (Rafał Domagała, Maja Gomulska, Bartosz Jakubowski, Gabriela Sułkowska), Xtreme Girl (Lena Peplińska, Laura Radzewicz), Ada Zielińska", link: "https://zacheta.art.pl/pl/wystawy/z-popiolow", year: 2024, tags: ["Exhibition"] },
  { title: "Future-oriented Ljubljana", text: "New article was published in the Contemporary Lynx Magazine. I write there about five artists whom I had the pleasure of meeting this summer in Slovenia. They operate at the intersection of art and technology, creating digital projects that explore AI and form hybrid online identities.", link: "https://contemporarylynx.co.uk/future-oriented-ljubljana", year: 2024, tags: ["Publication"] },
  { title: "Art Update", text: "The new issue of Art Monitor is now available, where you can read my extensive article about digital artists titled \"Art Update.\" Based on conversations with the creators, I write about how they operate on the boundary between the real and the virtual, how they translate digital art and aesthetics into the physical space of galleries, and finally, how they navigate the art market. Artists: Rafał Dominik, Sebulec, Franek Warzywa, Karolina Jarzębak, Zofia Pałucha, Laurą Radzewicz, Lena Peplińska, Justyna Górowska, Eternal Engine, Ernest Borowski, Wiktor Gałka, Kat Zavada, Dominik Jałowiński. Available in Empik Stores in Poland!", link: "https://artmonitor.bigcartel.com", year: 2024, tags: ["Publication"] },
  { title: "Polish & Belarusian AI Artists", text: "In the latest issue of the Orońsko Sculpture Quarterly accompanying the Youth Triennial, I write about Polish and Belarusian artists who use new AI tools and image generators in their artistic practice. They critically address issues related to technology development, surveillance and deep fakes in the Internet. I'm covering works of the Eternal Engine duo, Zofia Pałucha, Laura Radzewicz, Karolina Jarzębak, Agata Lankamer, Hleb Burnashev and Sasha Vielichko. Magazines available in Empik stores and on the website of the Polish Sculpture Center in Orońsko.", link: "https://ksiegarnia.rzezba-oronsko.pl/index.php?cPath=1", year: 2024, tags: ["Publication"] },
  { title: "Dear Future Exhibition", text: "The next installment of the Dear Future project, a Ukrainian-Polish exhibition reflecting on the future in the context of crises, will be available for viewing from November 24th at the Galeria Bielska BWA. I am very excited to be able to coordinate this project with wonderful and dedicated persons! Artists: Danylo Halkin, Maria Matiashova, Nazar Furyk, BRDA Foundation, fantastic little splash, Marta Romankiv, Pamela Bożek, Małgorzata Mycek, Alicja Czyczel, Livyj Bereh, Weronika Zalewska, Anna Sydorenko. Curators: Yulia Krivich, Anita Németh. Location: Bielska BWA Gallery (Willa Sixta), Bielsko-Biała, Poland. Opening: November 24, 2023, at 6:00 PM.", link: "https://galeriabielska.pl/wystawa/dear-future-vol-2", year: 2023, tags: ["Exhibition"] },
  { title: "New Article: David Hockney's iPad", text: "Seemingly, there is nothing exciting here – a gallery in New York is exhibiting the works of an artist as recognizable and renowned as David Hockney, presenting a series of his latest paintings, the subject matter of which seems quite conventional. These are primarily colorful images of flowers in vases, i.e. traditional still lifes. What arouses emotions here is the technique of making the works – the 86-year-old artist painted all of them using an iPad. New text for Moodaily covering an exhibition by David Hockney at David Benrimon Fine Art Gallery in New York.", link: "https://moodscentbar.com/pl/moodaily/post/135_ipad-davida-hockneya", year: 2023, tags: ["Publication"] },
  { title: "New Article: Autumn 2023 Best Exhibitions", text: "I have browsed through exhibitions in the most important European art galleries for you and made a subjective selection. In the autumn of 2023, we will see a lot of revolutionaries, women, and queerness.", link: "https://moodscentbar.com/pl/moodaily/post/131_najwazniejsze-wystawy-jesieni-2023", year: 2023, tags: ["Publication"] },
  { title: "Vogue: Young Talents", text: "I am immensely delighted to have been featured as one of the protagonists in the article 'Young Talents: On the Threshold of Fame' within the latest September edition of Vogue Magazine. I proudly represent the realm of visual arts, offering a narrative of my curatorial practice.", link: "https://www.vogue.pl", year: 2023, tags: ["Interview"] },
];
---
<Base title="News — Michalina Sablik">
  <div class="container page-content">
    <div class="year-tabs" style="display: flex; gap: 1rem; margin-bottom: 2rem; margin-top: 2rem; flex-wrap: wrap;">
      <button class="year-tab active" data-year="2026">2026</button>
      <button class="year-tab" data-year="2025">2025</button>
      <button class="year-tab" data-year="2024">2024</button>
      <button class="year-tab" data-year="2023">2023</button>
    </div>
    <div class="tag-filters" style="display: flex; gap: 0.5rem; margin-bottom: 2rem; flex-wrap: wrap;">
      <button class="tag-filter active" data-tag="all">All</button>
      <button class="tag-filter" data-tag="Exhibition">Exhibition</button>
      <button class="tag-filter" data-tag="Publication">Publication</button>
      <button class="tag-filter" data-tag="Lecture">Lecture</button>
      <button class="tag-filter" data-tag="Performance">Performance</button>
      <button class="tag-filter" data-tag="Interview">Interview</button>
    </div>
    <div class="news-list">
      {news.map((item, i) => (
        <div class="news-item" data-year={item.year} data-tags={item.tags.join(',')}>
          <div class="news-image">
            {item.link ? (
              <a href={item.link} target="_blank" rel="noopener">
                <img src={`/images/news/news-${i + 1}.jpg`} alt={item.title} loading="lazy"
                  onerror="this.src=this.src.replace('.jpg','.png');this.onerror=()=>{this.src=this.src.replace('.png','.jpeg');this.onerror=()=>{this.src=this.src.replace('.jpeg','.webp');this.onerror=null}}" />
              </a>
            ) : (
              <img src={`/images/news/news-${i + 1}.jpg`} alt={item.title} loading="lazy"
                onerror="this.src=this.src.replace('.jpg','.png');this.onerror=()=>{this.src=this.src.replace('.png','.jpeg');this.onerror=()=>{this.src=this.src.replace('.jpeg','.webp');this.onerror=null}}" />
            )}
          </div>
          <div class="news-content">
            <h3>
              {item.link ? (
                <a href={item.link} target="_blank" rel="noopener">{item.title}</a>
              ) : (
                item.title
              )}
            </h3>
            {item.tags && item.tags.length > 0 && (
              <div class="news-tags">
                {item.tags.map((tag: string) => <span class="news-tag">{tag}</span>)}
              </div>
            )}
            {item.details && <p class="news-details">{item.details}</p>}
            {item.text.split('\n').map((para: string) => <p>{para}</p>)}
          </div>
        </div>
      ))}
    </div>
  </div>
  <style>
    .year-tabs {
      border-bottom: 1px solid #333;
      padding-bottom: 0;
    }
    .year-tab {
      background: none;
      border: none;
      color: #999;
      font-size: 1.1rem;
      padding: 0.5rem 1rem;
      cursor: pointer;
      border-bottom: 2px solid transparent;
      margin-bottom: -1px;
      transition: color 0.2s, border-color 0.2s;
      font-family: inherit;
    }
    .year-tab:hover {
      color: #fff;
    }
    .year-tab.active {
      color: #000;
      font-weight: 700;
      border-bottom-color: #000;
    }
    .news-item {
      display: grid;
      grid-template-columns: 300px 1fr;
      gap: 1.5rem;
      align-items: start;
    }
    .news-item[data-year] {
      display: none;
    }
    .news-item.visible {
      display: grid;
    }
    .news-content h3 {
      font-size: 1.4rem;
      margin-bottom: 0.5rem;
    }
    .news-content p {
      font-size: 1.05rem;
      line-height: 1.6;
    }
    .news-image img {
      width: 100%;
      aspect-ratio: 1;
      object-fit: cover;
      border-radius: 4px;
      cursor: pointer;
    }
    .news-details {
      font-size: 1rem;
      color: #999;
      margin-bottom: 0.5rem;
    }
    .news-tags {
      display: flex;
      gap: 0.4rem;
      flex-wrap: wrap;
      margin-bottom: 0.6rem;
    }
    .news-tag {
      display: inline-block;
      font-size: 0.75rem;
      padding: 0.2rem 0.6rem;
      border: 1px solid #555;
      border-radius: 20px;
      color: #888;
      letter-spacing: 0.03em;
      text-transform: uppercase;
      font-family: inherit;
    }
    .tag-filters {
      padding-bottom: 0;
    }
    .tag-filter {
      background: none;
      border: 1px solid #555;
      color: #999;
      font-size: 0.85rem;
      padding: 0.3rem 0.8rem;
      cursor: pointer;
      border-radius: 20px;
      transition: color 0.2s, border-color 0.2s, background 0.2s;
      font-family: inherit;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }
    .tag-filter:hover {
      color: #fff;
      border-color: #fff;
    }
    .tag-filter.active {
      color: #fff;
      background: #000;
      border-color: #000;
    }
    @media (max-width: 700px) {
      .news-item.visible {
        grid-template-columns: 1fr;
      }
      .news-image img {
        aspect-ratio: 16/9;
        max-height: 300px;
      }
    }
  </style>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const yearTabs = document.querySelectorAll('.year-tab');
      const tagFilters = document.querySelectorAll('.tag-filter');
      const items = document.querySelectorAll('.news-item[data-year]');
      let activeYear = '2026';
      let activeTag = 'all';

      function filterItems() {
        items.forEach(item => {
          const matchYear = item.getAttribute('data-year') === activeYear;
          const tags = (item.getAttribute('data-tags') || '').split(',');
          const matchTag = activeTag === 'all' || tags.includes(activeTag);
          if (matchYear && matchTag) {
            item.classList.add('visible');
          } else {
            item.classList.remove('visible');
          }
        });
      }

      yearTabs.forEach(tab => {
        tab.addEventListener('click', () => {
          activeYear = tab.getAttribute('data-year');
          yearTabs.forEach(t => t.classList.remove('active'));
          tab.classList.add('active');
          filterItems();
        });
      });

      tagFilters.forEach(btn => {
        btn.addEventListener('click', () => {
          activeTag = btn.getAttribute('data-tag');
          tagFilters.forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          filterItems();
        });
      });

      filterItems();
    });
  </script>
</Base>
