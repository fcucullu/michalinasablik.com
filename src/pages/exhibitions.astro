---
import Base from '../layouts/Base.astro';

const exhibitions = [
  { title: "Permitted Vulnerability. Gvantsa Jishkariani", venue: "Espai Souvenir | Barcelona", year: "2026", slug: "permitted-vulnerability" },
  { title: "to undo, to crumble, to vanish. Laureta Hajrullahu", venue: "National Gallery of Kosovo QAFA | Pristina", year: "2026", slug: "text-laureta" },
  { title: "Other Tomorrows / City of Women", venue: "Museum of Modern Art | Warsaw", year: "2025–2026", slug: "other-tomorrows" },
  { title: "A View of One's Own by Paulina Stasik", venue: "BWA | Tarnów", year: "2025", slug: "paulina-stasik" },
  { title: "Slime by Joanna Fluder", venue: "Zachęta National Gallery | Warsaw", year: "2025", slug: "slime-by-joanna-fluder" },
  { title: "Soft Smiths. Contemporary Women's* Metalwork", venue: "Center of Polish Sculpture | Orońsko", year: "2025", slug: "soft-smiths" },
  { title: "Hyperlocality. Personal Cartographies", venue: "CasCaDas ArtSpace | Barcelona", year: "2025", slug: "hyperlocality" },
  { title: "Mammals&Suckers", venue: "HOS Gallery | Warsaw", year: "2025", slug: "mammalssuckers" },
  { title: "Justyna Smoleń: Fragile Dreams", venue: "Bunkier Sztuki | Kraków", year: "2025", slug: "fragile-dreams" },
  { title: "A Man Eating His Own Tail", venue: "CasCaDas ArtSpace | Barcelona", year: "2024", slug: "a-man-eating-his-own-tail" },
  { title: "We Are a Dream", venue: "Kunsthalle.Ost | Leipzig", year: "2024", slug: "we-are-a-dream" },
  { title: "From The Ashes", venue: "Zachęta National Gallery | Warsaw", year: "2024", slug: "from-the-ashes" },
  { title: "Apparently Small Significance of Puddles", venue: "Art Walk Gallery", year: "2023", slug: "exhibition-1" },
  { title: "Hit Me With Your Car", venue: "Galeria Promocyjna | Warsaw", year: "2023", slug: "hit-me-with-your-car" },
  { title: "I Stand in Front of the Mirror Like Dog and Paint", venue: "HOS Gallery | Warsaw", year: "2023", slug: "maja-krysiak" },
  { title: "Skin Deep", venue: "KRAKERS | Kraków", year: "2023", slug: "skin-deep" },
  { title: "And Rivers Will Flow with Date Syrup", venue: "Galeria Promocyjna | Warsaw", year: "2023", slug: "ania-grzymala" },
  { title: "Quench Thirst with Dew", venue: "UFO Art Gallery | Kraków", year: "2023", slug: "quench-thirst-with-dew" },
  { title: "Cold Lips of the Waves", venue: "Gdańska Galeria Miejska | Gdańsk", year: "2022", slug: "cold-lips-of-waves" },
  { title: "Room of Projected Horizons", venue: "Galeria Promocyjna | Warsaw", year: "2022", slug: "room-of-projected-horizons" },
  { title: "In these days of tumult, heat and dazzle…", venue: "Stefan Gierowski's Foundation | Warsaw", year: "2021", slug: "in-these-days-of-tumult-heat-and-dazzle" },
  { title: "Pure Crystal", venue: "Galeria Promocyjna | Warsaw", year: "2021", slug: "czysty-krysztal" },
  { title: "Warsaw Preview", venue: "Jazdów | Warsaw", year: "2021", slug: "warsaw-preview" },
  { title: "Year on the Protests", venue: "Krakow Photomonth | Kraków", year: "2021", slug: "year-on-protest" },
  { title: "A Dream Within a Dream", venue: "Magic Garden | Warsaw", year: "2020", slug: "sen-we-snie" },
  { title: "Beautiful Losers", venue: "Jak zapomnieć | Kraków", year: "2020", slug: "beautiful-loosers" },
  { title: "Poland of Our Dreams", venue: "Warsaw", year: "2019", slug: "poland-of-our-dreams" },
  { title: "Snake-Man", venue: "Jak zapomnieć | Kraków", year: "2019", slug: "snake-man" },
  { title: "Apetite", venue: "Warsaw", year: "2018", slug: "apetite" },
  { title: "#behappyalways", venue: "Warsaw", year: "2018", slug: "behappyalways" },
];
---
<Base title="Exhibitions — Michalina Sablik">
  <div class="container page-content">
    <div class="exhibition-list" style="margin-top: 2rem; display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem;">
      {exhibitions.map((ex, i) => (
        <div class="exhibition-entry" style="margin-bottom: 0;">
          {ex.slug ? (
            <a href={`/exhibitions/${ex.slug}/`}>
              <img src={`/images/exhibitions/ex-${i + 1}.jpg`} alt={ex.title} loading="lazy"
                style="width:100%;max-height:350px;object-fit:cover;margin-bottom:0.8rem;"
                onerror="this.src=this.src.replace('.jpg','.png');this.onerror=()=>{this.src=this.src.replace('.png','.jpeg');this.onerror=null}" />
            </a>
          ) : (
            <img src={`/images/exhibitions/ex-${i + 1}.jpg`} alt={ex.title} loading="lazy"
              style="width:100%;max-height:350px;object-fit:cover;margin-bottom:0.8rem;"
              onerror="this.src=this.src.replace('.jpg','.png');this.onerror=()=>{this.src=this.src.replace('.png','.jpeg');this.onerror=null}" />
          )}
          <div class="exhibition-item">
            <div>
              {ex.slug ? (
                <a href={`/exhibitions/${ex.slug}/`} class="exhibition-title">{ex.title}</a>
              ) : (
                <span class="exhibition-title">{ex.title}</span>
              )}
            </div>
            <div class="exhibition-venue">{ex.venue} | {ex.year}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
  <style>
    .exhibition-item {
      margin-top: 0.6rem;
    }
    .exhibition-title {
      font-weight: 600;
      font-size: 0.95rem;
      line-height: 1.3;
      display: block;
      margin-bottom: 0.25rem;
    }
    .exhibition-venue {
      font-size: 0.8rem;
      color: #888;
      line-height: 1.3;
    }
    @media (max-width: 900px) {
      .exhibition-list { grid-template-columns: repeat(2, 1fr) !important; }
    }
    @media (max-width: 600px) {
      .exhibition-list { grid-template-columns: 1fr !important; }
    }
  </style>
</Base>
