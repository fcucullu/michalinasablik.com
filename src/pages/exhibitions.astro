---
import Base from '../layouts/Base.astro';
import { exhibitions } from '../data/exhibitions.js';

// Distinct years (newest first) for the year filter, like the News page.
// A "2025–2026" range contributes to BOTH years.
const years = [...new Set(exhibitions.flatMap((e) => e.year.match(/\d{4}/g) ?? []))].sort((a, b) => b.localeCompare(a));
const defaultYear = years[0];
---
<Base title="Exhibitions — Michalina Sablik">
  <div class="container page-content">
    <div class="year-tabs" style="display: flex; gap: 1rem; margin-bottom: 0.5rem; margin-top: 2rem; flex-wrap: wrap;">
      {years.map((y) => (
        <button class={`year-tab${y === defaultYear ? " active" : ""}`} data-year={y}>{y}</button>
      ))}
    </div>
    <div class="exhibition-list" style="margin-top: 1.5rem; display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem;">
      {exhibitions.map((ex) => (
        <div class={`exhibition-entry${ex.year.includes(defaultYear) ? " visible" : ""}`} data-year={ex.year} style="margin-bottom: 0;">
          {ex.slug ? (
            <a href={`/exhibitions/${ex.slug}/`}>
              <img src={`/images/exhibitions/ex-${ex.imgIndex}.jpg`} alt={ex.title} loading="lazy"
                style="width:100%;max-height:350px;object-fit:cover;margin-bottom:0.8rem;"
                onerror="this.src=this.src.replace('.jpg','.png');this.onerror=()=>{this.src=this.src.replace('.png','.jpeg');this.onerror=null}" />
            </a>
          ) : (
            <img src={`/images/exhibitions/ex-${ex.imgIndex}.jpg`} alt={ex.title} loading="lazy"
              style="width:100%;max-height:350px;object-fit:cover;margin-bottom:0.8rem;"
              onerror="this.src=this.src.replace('.jpg','.png');this.onerror=()=>{this.src=this.src.replace('.png','.jpeg');this.onerror=null}" />
          )}
          <div class="exhibition-item">
            <div>
              {ex.slug ? (
                <a href={`/exhibitions/${ex.slug}/`} class="exhibition-title">{ex.title}</a>
              ) : (
                <span class="exhibition-title">{ex.title}</span>
              )}
            </div>
            <div class="exhibition-venue">{ex.venue} | {ex.year}</div>
            {ex.tags?.includes("Dzidy") && (
              <a href="/exhibitions/dzidy/" class="exhibition-tag">DZIDY</a>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
  <style>
    .year-tabs {
      border-bottom: 1px solid #333;
      padding-bottom: 0;
    }
    .year-tab {
      background: none;
      border: none;
      color: #999;
      font-size: 1.1rem;
      padding: 0.5rem 1rem;
      cursor: pointer;
      border-bottom: 2px solid transparent;
      margin-bottom: -1px;
      transition: color 0.2s, border-color 0.2s;
      font-family: inherit;
    }
    .year-tab:hover { color: #000; }
    .year-tab.active {
      color: #000;
      font-weight: 700;
      border-bottom-color: #000;
    }
    .exhibition-entry[data-year] { display: none; }
    .exhibition-entry.visible { display: block; }
    .exhibition-item {
      margin-top: 0.6rem;
    }
    .exhibition-title {
      font-weight: 600;
      font-size: 0.95rem;
      line-height: 1.3;
      display: block;
      margin-bottom: 0.25rem;
    }
    .exhibition-venue {
      font-size: 0.8rem;
      color: #888;
      line-height: 1.3;
    }
    .exhibition-tag {
      display: inline-block;
      margin-top: 0.4rem;
      font-size: 0.7rem;
      letter-spacing: 0.08em;
      color: #888;
      border: 1px solid #ccc;
      padding: 0.1rem 0.5rem;
      border-radius: 2px;
      transition: color 0.2s, border-color 0.2s;
    }
    .exhibition-tag:hover {
      color: #000;
      border-color: #000;
    }
    @media (max-width: 900px) {
      .exhibition-list { grid-template-columns: repeat(2, 1fr) !important; }
    }
    @media (max-width: 600px) {
      .exhibition-list { grid-template-columns: 1fr !important; }
    }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const yearTabs = document.querySelectorAll('.year-tab');
      const entries = document.querySelectorAll('.exhibition-entry[data-year]');
      let activeYear = yearTabs.length ? yearTabs[0].getAttribute('data-year') : '';
      function filterEntries() {
        entries.forEach((el) => {
          const y = el.getAttribute('data-year') || '';
          if (activeYear && y.includes(activeYear)) el.classList.add('visible');
          else el.classList.remove('visible');
        });
      }
      yearTabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          activeYear = tab.getAttribute('data-year');
          yearTabs.forEach((t) => t.classList.remove('active'));
          tab.classList.add('active');
          filterEntries();
        });
      });
      filterEntries();
    });
  </script>
</Base>
