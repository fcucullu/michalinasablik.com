---
import Base from '../layouts/Base.astro';

const slides = [
  { image: "/images/exhibitions/permitted-vulnerability/2.jpg", mobileImage: "/images/exhibitions/permitted-vulnerability/1.jpg", title: "Permitted Vulnerability. Gvantsa Jishkariani", subtitle: "Espai Souvenir, Barcelona | 2026", link: "/exhibitions/permitted-vulnerability/", type: "exhibition" },
  { image: "/images/news/news-3-hero.jpg", title: "Hydrosex Call: Justyna Górowska", subtitle: "Zagreb: Pogon Jedinstvo | April 23, 2026", link: "/news/", type: "news" },
  { image: "/images/exhibitions/text-laureta/1.jpg", title: "to undo, to crumble, to vanish. Laureta Hajrullahu", subtitle: "National Gallery of Kosovo QAFA | 2026", link: "/exhibitions/text-laureta/", type: "exhibition" },
  { image: "/images/news/news-7.jpg", mobileImage: "/images/news/news-7-mobile.jpg", title: "Artysta Zawodowiec: The ING Polish Art Foundation", subtitle: "Lecturer and portfolio consultant | March 2026", link: "/news/", type: "news" },
  { image: "/images/exhibitions/other-tomorrows/1.jpg", title: "Other Tomorrows / City of Women", subtitle: "Museum of Modern Art in Warsaw | 2025–2026", link: "/exhibitions/other-tomorrows/", type: "exhibition" },
  { image: "/images/news/news-5.jpg", title: "Book Launch: Liliana Zeic's Monograph", subtitle: "Warsaw: Museum of Modern Art | March 2026", link: "/news/", type: "news" },
];
---
<Base title="Michalina Sablik — Art Curator">
  <div class="slideshow">
    {slides.map((slide, i) => (
      <div class={`slide ${i === 0 ? 'active' : ''}`} data-index={i}>
        {slide.mobileImage ? (
          <picture>
            <source media="(max-width: 700px)" srcset={slide.mobileImage} />
            <img src={slide.image} alt={slide.title} />
          </picture>
        ) : (
          <img src={slide.image} alt={slide.title} />
        )}
        <div class="slide-overlay">
          <span class="slide-type">{slide.type}</span>
          <h2 class="slide-title">
            {slide.link ? (
              <a href={slide.link} target={slide.link.startsWith('http') ? '_blank' : '_self'} rel="noopener">{slide.title}</a>
            ) : (
              slide.title
            )}
          </h2>
          <p class="slide-subtitle">{slide.subtitle}</p>
        </div>
      </div>
    ))}
    <button class="slide-prev" onclick="slideNav(-1)">&#8249;</button>
    <button class="slide-next" onclick="slideNav(1)">&#8250;</button>
    <div class="slide-dots">
      {slides.map((_, i) => (
        <button class={`dot ${i === 0 ? 'active' : ''}`} data-dot={i} onclick={`goSlide(${i})`} />
      ))}
    </div>
  </div>

  <!-- Video section -->
  <div class="container" style="margin-top: 4rem; margin-bottom: 4rem;">
    <h2 style="font-size: 1.8rem; font-weight: 700; margin-bottom: 2rem;">Watch Recent Videos with Lectures & Talks</h2>
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
      <div style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 4px;">
        <iframe src="https://www.youtube.com/embed/JKKecKtBJAU" title="Lecture" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"></iframe>
      </div>
      <div style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 4px;">
        <iframe src="https://www.youtube.com/embed/Qj8U8Z4Ec2o" title="Talk" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"></iframe>
      </div>
    </div>
  </div>

  <style>
    .slideshow {
      position: relative;
      width: 100vw;
      height: calc(100vh - 70px);
      margin-left: calc(-50vw + 50%);
      overflow: hidden;
    }
    .slide {
      position: absolute;
      inset: 0;
      opacity: 0;
      transition: opacity 0.8s ease;
    }
    .slide.active { opacity: 1; }
    .slide img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .slide-overlay {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 3rem 4rem;
      background: linear-gradient(transparent, rgba(0,0,0,0.7));
    }
    .slide-type {
      text-transform: uppercase;
      font-size: 0.7rem;
      letter-spacing: 2px;
      color: rgba(255,255,255,0.6);
      margin-bottom: 0.5rem;
      display: block;
    }
    .slide-title {
      font-size: 2rem;
      font-weight: 600;
      color: #fff;
      margin-bottom: 0.5rem;
    }
    .slide-title a {
      color: #fff;
      text-decoration: none;
    }
    .slide-title a:hover { text-decoration: underline; }
    .slide-subtitle {
      font-size: 0.95rem;
      color: rgba(255,255,255,0.7);
      font-weight: 300;
    }
    .slide-prev, .slide-next {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      font-size: 3rem;
      color: rgba(255,255,255,0.7);
      background: none;
      border: none;
      cursor: pointer;
      padding: 1rem;
      z-index: 10;
    }
    .slide-prev { left: 1rem; }
    .slide-next { right: 1rem; }
    .slide-prev:hover, .slide-next:hover { color: #fff; }
    .slide-dots {
      position: absolute;
      bottom: 1.5rem;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      gap: 0.5rem;
      z-index: 10;
    }
    .dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.5);
      background: transparent;
      cursor: pointer;
      transition: background 0.3s;
    }
    .dot.active { background: #fff; }
    @media (max-width: 700px) {
      .slideshow { height: 100svh; height: calc(100vh - 60px); }
      .slide-overlay { padding: 1.5rem 1.25rem 4rem; background: linear-gradient(transparent 0%, rgba(0,0,0,0.8) 50%); }
      .slide-type { font-size: 0.6rem; margin-bottom: 0.3rem; }
      .slide-title { font-size: 1.1rem; line-height: 1.3; margin-bottom: 0.3rem; }
      .slide-subtitle { font-size: 0.8rem; }
      .slide-prev, .slide-next { font-size: 2rem; padding: 0.5rem; }
      .slide-dots { bottom: 1rem; }
      .dot { width: 8px; height: 8px; }
    }
  </style>

  <script is:inline>
    const totalSlides = 6;
    let current = 0;
    let timer;

    function goSlide(n) {
      document.querySelectorAll('.slide').forEach(s => s.classList.remove('active'));
      document.querySelectorAll('.dot').forEach(d => d.classList.remove('active'));
      current = n;
      document.querySelector(`.slide[data-index="${current}"]`).classList.add('active');
      document.querySelector(`.dot[data-dot="${current}"]`).classList.add('active');
      resetTimer();
    }

    function slideNav(dir) {
      goSlide((current + dir + totalSlides) % totalSlides);
    }

    function resetTimer() {
      clearInterval(timer);
      timer = setInterval(() => slideNav(1), 5000);
    }

    window.goSlide = goSlide;
    window.slideNav = slideNav;
    resetTimer();
  </script>
</Base>
