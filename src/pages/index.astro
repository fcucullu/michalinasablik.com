---
import Base from '../layouts/Base.astro';
---
<Base title="Michalina Sablik — Art Curator">
  <div class="container">
    <div class="newsletter">
      <h3>Subscribe to my monthly newsletter</h3>
      <form>
        <input type="email" placeholder="Your email" />
        <button type="submit">Subscribe</button>
      </form>
    </div>

    <div class="hero-image">
      <a href="https://artmuseum.pl/en/exhibitions/the-city-of-women" target="_blank">
        <img src="/images/hero.jpg" alt="The City of Women exhibition" />
      </a>
    </div>
  </div>
</Base>
