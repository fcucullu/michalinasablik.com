---
import Base from '../layouts/Base.astro';
---
<Base title="Writtings — Michalina Sablik">
  <div class="container page-content">
    <h1>Writtings</h1>

    <div style="margin-top: 2rem;">
      <div class="writing-item">
        <h3>Lurking, Aesthetic of Withdrawal and Y2K. On Laureta Hajrullahu's Practice</h3>
        <p class="writing-meta">Curatorial text — "to undo, to crumble, to vanish" by Laureta Hajrullahu, National Gallery of Kosovo, Pristina — March 11 – May 14, 2026</p>
        <p>An examination of Hajrullahu's video-based practice and immersive installations drawing on digital folklore and online identity, addressing privacy, gender, and postdigital futures.</p>
      </div>

      <div class="writing-item">
        <h3>Brainrot: Affect and Feminist Strategies in Si On's Art</h3>
        <p class="writing-meta">Catalogue text — Solo show by Si On at Bunkier Sztuki, Kraków — April 2026</p>
        <p>An analysis of Si On's work through feminist and affect theory lenses.</p>
      </div>

      <div class="writing-item">
        <h3>Hay. The Phantasmagorical Work of Anna Raczyńska</h3>
        <p class="writing-meta">Solo publication — "Old Habits, New Beginnings" — 200+ page dual-language (Polish–German) with English section</p>
        <p>A publication featuring essays by Michalina Sablik and Sophia Scherer, with design by Karolina Pierzyk and Tobias Wenig. Contains 178 photographs documenting 10 years of transdisciplinary practice across Europe.</p>
      </div>
    </div>
  </div>
</Base>
