---
import Base from '../layouts/Base.astro';
---
<Base title="Writings — Michalina Sablik">
  <div class="container page-content">
    <h1>Writings</h1>

    <!-- Essays in artist catalogues -->
    <h2 class="writings-category">Essays in Artist Catalogues</h2>
    <div class="writings-mosaic">
      <a href="/writings/si-on-brainrot" class="mosaic-tile mosaic-large">
        <img src="/images/writings/writing-2.jpg" alt="Brainrot — Si On" loading="lazy" />
        <div class="mosaic-overlay">
          <span class="mosaic-tag">Catalogue Essay</span>
          <h3>Brainrot: Affect and Feminist Strategies in Si On's Work</h3>
          <p>Si On, Bunkier Sztuki, Kraków 2026</p>
        </div>
      </a>
      <a href="https://michalinasablik.com/exhibitions/text-laureta/" class="mosaic-tile mosaic-medium">
        <img src="/images/writings/writing-1.png" alt="Lurking — Laureta Hajrullahu" loading="lazy" />
        <div class="mosaic-overlay">
          <span class="mosaic-tag">Curatorial Text</span>
          <h3>Lurking, Aesthetic of Withdrawal and Y2K</h3>
          <p>Laureta Hajrullahu, National Gallery of Kosovo, Pristina 2026</p>
        </div>
      </a>
    </div>

    <!-- My books -->
    <h2 class="writings-category">My Books</h2>
    <div class="writings-mosaic">
      <a href="https://michalinasablik.com/exhibitions/text-raczynska/" class="mosaic-tile mosaic-medium">
        <img src="/images/writings/writing-3.jpg" alt="Hay — Anna Raczyńska" loading="lazy" />
        <div class="mosaic-overlay">
          <span class="mosaic-tag">Solo Publication</span>
          <h3>Hay. The Phantasmagorical Work of Anna Raczyńska</h3>
          <p>Old Habits, New Beginnings — dual-language, 200+ pages</p>
        </div>
      </a>
    </div>

    <!-- Articles (placeholder) -->
    <h2 class="writings-category">Articles</h2>
    <div class="writings-mosaic">
      <div class="mosaic-tile mosaic-small mosaic-placeholder">
        <div class="mosaic-overlay">
          <p>Coming soon</p>
        </div>
      </div>
    </div>

    <!-- Academic texts (placeholder) -->
    <h2 class="writings-category">Academic Texts</h2>
    <div class="writings-mosaic">
      <div class="mosaic-tile mosaic-small mosaic-placeholder">
        <div class="mosaic-overlay">
          <p>Coming soon</p>
        </div>
      </div>
    </div>
  </div>
</Base>
