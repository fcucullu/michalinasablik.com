---
import Base from '../../layouts/Base.astro';
---
<Base title="A Dream Within a Dream — Michalina Sablik">
  <div class="container page-content">
    <h1>A Dream Within a Dream</h1>
    <p class="exhibition-detail-venue">Warsaw | 2020</p>
    <div class="exhibition-detail-body">
      <p>Site-specific group exhibition in an outdoor garden setting. The curatorial concept draws inspiration from Edgar Allan Poe's poem "A Dream Within a Dream," exploring themes of perception, reality, and the dreamlike nature of experience.</p>
    </div>
    <div class="exhibition-detail-credits">
      <p><strong>Artists:</strong> Marceli Adamczyk, Jan Eustachy Wolski, Marta Niedbał, Aleksandra Liput, Øleg&Kaśka, Karolina Jarzębak</p>
      <p><strong>Curators:</strong> Dzidy (Michalina Sablik, Aleksandra Liput)</p>
      <p><strong>Photographer:</strong> Bartosz Górka</p>
    </div>
    <div class="exhibition-gallery" style="margin-top: 2.5rem; display: grid; gap: 1rem;">
      <img src="/images/exhibitions/sen-we-snie/1.jpg" alt="Exhibition view" loading="lazy" style="width:100%; border-radius: 4px;" />
      <img src="/images/exhibitions/sen-we-snie/2.jpg" alt="Exhibition view" loading="lazy" style="width:100%; border-radius: 4px;" />
