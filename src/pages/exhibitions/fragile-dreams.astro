---
import Base from '../../layouts/Base.astro';
---
<Base title="Fragile Dreams — Michalina Sablik">
  <div class="container page-content">
    <h1>Fragile Dreams</h1>
    <p class="exhibition-detail-venue">Bunkier Sztuki, Kraków | 2025</p>
    <div class="exhibition-detail-body">
      <p>The exhibition features objects, installations, collage and ceramics by Justyna Smoleń. The accompanying catalog includes texts by Olga Drenda, Ewa Borysewicz, and an interview by Michalina Sablik.</p>
    </div>
    <div class="exhibition-detail-credits">
      <p><strong>Curator:</strong> Michalina Sablik</p>
    </div>
    <div class="exhibition-gallery" style="margin-top: 2.5rem; display: grid; gap: 1rem;">
      <img src="/images/exhibitions/fragile-dreams/1.jpg" alt="Exhibition view" loading="lazy" style="width:100%; border-radius: 4px;" />
