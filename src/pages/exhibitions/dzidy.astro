---
import Base from '../../layouts/Base.astro';
import { exhibitions } from '../../data/exhibitions.js';

const dzidyExhibitions = exhibitions.filter((e) => e.tags?.includes("Dzidy"));
---
<Base title="DZIDY — Michalina Sablik">
  <div class="container page-content">
    <div class="dzidy-intro">
      <h1>DZIDY</h1>
      <p>The curatorial duo DZIDY, founded by Aleksandra Liput and Michalina Sablik, was active from 2018 to 2021 in Warsaw. Together they organized pop-up, group, site-specific exhibitions in unconventional spaces, inviting Polish and international artists of the young generation to collaborate. They were interested in contemporary issues related to politics, identity, gender, neo-tribalism, and post-internet aesthetics.</p>
    </div>
    <div class="exhibition-list" style="margin-top: 2.5rem; display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem;">
      {dzidyExhibitions.map((ex) => (
        <div class="exhibition-entry" style="margin-bottom: 0;">
          {ex.slug ? (
            <a href={`/exhibitions/${ex.slug}/`}>
              <img src={`/images/exhibitions/ex-${ex.imgIndex}.jpg`} alt={ex.title} loading="lazy"
                style="width:100%;max-height:350px;object-fit:cover;margin-bottom:0.8rem;"
                onerror="this.src=this.src.replace('.jpg','.png');this.onerror=()=>{this.src=this.src.replace('.png','.jpeg');this.onerror=null}" />
            </a>
          ) : (
            <img src={`/images/exhibitions/ex-${ex.imgIndex}.jpg`} alt={ex.title} loading="lazy"
              style="width:100%;max-height:350px;object-fit:cover;margin-bottom:0.8rem;"
              onerror="this.src=this.src.replace('.jpg','.png');this.onerror=()=>{this.src=this.src.replace('.png','.jpeg');this.onerror=null}" />
          )}
          <div class="exhibition-item">
            <div>
              {ex.slug ? (
                <a href={`/exhibitions/${ex.slug}/`} class="exhibition-title">{ex.title}</a>
              ) : (
                <span class="exhibition-title">{ex.title}</span>
              )}
            </div>
            <div class="exhibition-venue">{ex.venue} | {ex.year}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
  <style>
    .dzidy-intro {
      margin-top: 2rem;
      max-width: 720px;
    }
    .dzidy-intro h1 {
      letter-spacing: 0.04em;
      margin-bottom: 1rem;
    }
    .dzidy-intro p {
      font-size: 1rem;
      line-height: 1.6;
      color: #444;
    }
    .exhibition-item {
      margin-top: 0.6rem;
    }
    .exhibition-title {
      font-weight: 600;
      font-size: 0.95rem;
      line-height: 1.3;
      display: block;
      margin-bottom: 0.25rem;
    }
    .exhibition-venue {
      font-size: 0.8rem;
      color: #888;
      line-height: 1.3;
    }
    @media (max-width: 900px) {
      .exhibition-list { grid-template-columns: repeat(2, 1fr) !important; }
    }
    @media (max-width: 600px) {
      .exhibition-list { grid-template-columns: 1fr !important; }
    }
  </style>
</Base>
