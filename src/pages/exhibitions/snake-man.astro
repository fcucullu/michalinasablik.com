---
import Base from '../../layouts/Base.astro';
const photos = [1, 2, 3, 4, 5, 6, 7, 8, 9];
---
<Base title="Snake-Man — Michalina Sablik">
  <div class="container page-content">
    <div class="ex-layout">
      <div class="ex-text">
    <h1>Snake-Man</h1>
    <p class="exhibition-detail-venue">Jak Zapomnieć Gallery | Kraków | 2019</p>
    <div class="exhibition-detail-body">
      <p>So who is the snake-man?</p>
      <p>a. an illuminatus, or a reptile born from satanic spawn<br/>b. a metaphorical lover lost in a desert<br/>c. Donald Trump<br/>d. your neighbour from flat no.5<br/>e. a gamer addicted to Slither.io<br/>f. youtuber under the nick of MattKeck<br/>g. a modern tribesman (sociological concept) originating from factors such as rebellion against extreme individualism in mass society, rejection of the logic of globalisation or neoliberalism, as well as undermining of social norms and distrust in the authority of science or government<br/>h. a sensational discovery of reporters<br/>i. an anime character<br/>j. a Shoshone</p>
    </div>
    <div class="exhibition-detail-credits">
      <p><strong>Artists:</strong> Aleksander Błaszkiewicz, Karolina Jarzębak, Angelika Grzegorczyk, Aleksander Sovtysik, Adrian Szwarc</p>
      <p><strong>Curator:</strong> Michalina Sablik</p>
    </div>
      </div>
      <div class="ex-thumbs">
        {photos.map((n) => (
          <img src={`/images/exhibitions/snake-man/${n}.jpg`} alt="Exhibition view" loading="lazy" class="thumb" data-index={n - 1} onclick="openLightbox(this.dataset.index)" />
        ))}
      </div>
    </div>
  </div>

  <!-- Lightbox -->
  <div id="lightbox" onclick="if(event.target===this)closeLightbox()">
    <button class="lb-close" onclick="closeLightbox()">&times;</button>
    <button class="lb-prev" onclick="navLightbox(-1)">&#8249;</button>
    <img id="lb-img" src="" alt="Exhibition view" />
    <button class="lb-next" onclick="navLightbox(1)">&#8250;</button>
  </div>

  <style>
    .ex-layout {
      display: grid;
      grid-template-columns: 1fr 280px;
      gap: 2.5rem;
      align-items: start;
    }
    .ex-thumbs {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.5rem;
    }
    .thumb {
      width: 100%;
      aspect-ratio: 1;
      object-fit: cover;
      border-radius: 3px;
      cursor: pointer;
      transition: opacity 0.2s;
    }
    .thumb:hover { opacity: 0.8; }
    @media (max-width: 700px) {
      .ex-layout { grid-template-columns: 1fr; }
      .ex-thumbs { grid-template-columns: 1fr 1fr 1fr; }
    }

    /* Lightbox */
    #lightbox {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.92);
      z-index: 9999;
      align-items: center;
      justify-content: center;
    }
    #lightbox.active { display: flex; }
    #lb-img {
      max-width: 90vw;
      max-height: 90vh;
      object-fit: contain;
      border-radius: 4px;
    }
    .lb-close {
      position: absolute;
      top: 1rem;
      right: 1.5rem;
      font-size: 2.5rem;
      color: #fff;
      background: none;
      border: none;
      cursor: pointer;
      z-index: 10;
    }
    .lb-prev, .lb-next {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      font-size: 3rem;
      color: #fff;
      background: none;
      border: none;
      cursor: pointer;
      padding: 1rem;
      z-index: 10;
    }
    .lb-prev { left: 1rem; }
    .lb-next { right: 1rem; }
    .lb-prev:hover, .lb-next:hover { color: #ccc; }
  </style>

  <script is:inline define:vars={{ photoCount: photos.length }}>
    const totalPhotos = photoCount;
    let currentIndex = 0;

    function openLightbox(index) {
      currentIndex = parseInt(index);
      document.getElementById('lb-img').src = `/images/exhibitions/snake-man/${currentIndex + 1}.jpg`;
      document.getElementById('lightbox').classList.add('active');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      document.getElementById('lightbox').classList.remove('active');
      document.body.style.overflow = '';
    }

    function navLightbox(dir) {
      currentIndex = (currentIndex + dir + totalPhotos) % totalPhotos;
      document.getElementById('lb-img').src = `/images/exhibitions/snake-man/${currentIndex + 1}.jpg`;
    }

    document.addEventListener('keydown', (e) => {
      if (!document.getElementById('lightbox').classList.contains('active')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') navLightbox(-1);
      if (e.key === 'ArrowRight') navLightbox(1);
    });

    window.openLightbox = openLightbox;
    window.closeLightbox = closeLightbox;
    window.navLightbox = navLightbox;
  </script>
</Base>
