---
import Base from '../../layouts/Base.astro';
---
<Base title="Apetite — Michalina Sablik">
  <div class="container page-content">
    <h1>Apetite</h1>
    <p class="exhibition-detail-venue">Former Ambassador Restaurant, Warsaw | 2019</p>
    <div class="exhibition-detail-body">
      <p>Exhibition featuring a recipe titled "Sinful Meat" from Otto Koch and Joachim Heer's 1997 cookbook "Erotic Menu or Aphrodite's Secrets." The recipe provides instructions for preparing calf tongue, sweetbread, and head cheese mixed with veal stuffing, formed into sausages and boiled.</p>
    </div>
    <div class="exhibition-detail-credits">
      <p><strong>Artists:</strong> Yui Akiyama, Jakub Gliński, Marcin Janusz, Martyna Kielesińska, Jan Możdżyński, Aleksandra Liput, Zofia Pałucha</p>
      <p><strong>Curators:</strong> Aleksandra Liput, Michalina Sablik (Dzidy Duo)</p>
    </div>
    <div class="exhibition-gallery" style="margin-top: 2.5rem; display: grid; gap: 1rem;">
      <img src="/images/exhibitions/apetite/1.jpg" alt="Exhibition view" loading="lazy" style="width:100%; border-radius: 4px;" />
