---
import Base from '../../layouts/Base.astro';
---
<Base title="#BeHappyAlways — Michalina Sablik">
  <div class="container page-content">
    <h1>#BeHappyAlways</h1>
    <p class="exhibition-detail-venue">Warsaw | 2018</p>
    <div class="exhibition-detail-body">
      <p>Features paintings and latex soft sculptures by Aleksandra Liput that critique exaggerated masculinity in Western culture. Incorporates provocative imagery including meatheads, pumped muscles, shaved heads and explicit phallic symbols rendered in a grotesque, caricatured style.</p>
      <p>Employs vulgar imagery borrowed from student notebooks, urban graffiti, and internet forums to challenge heteronormative expectations. Functions as social commentary using irony and absurdism.</p>
    </div>
    <div class="exhibition-detail-credits">
      <p><strong>Artist:</strong> Aleksandra Liput</p>
      <p><strong>Curator:</strong> Michalina Sablik</p>
    </div>
    <div class="exhibition-gallery" style="margin-top: 2.5rem; display: grid; gap: 1rem;">
      <img src="/images/exhibitions/behappyalways/1.jpg" alt="Exhibition view" loading="lazy" style="width:100%; border-radius: 4px;" />
      <img src="/images/exhibitions/behappyalways/2.jpg" alt="Exhibition view" loading="lazy" style="width:100%; border-radius: 4px;" />
      <img src="/images/exhibitions/behappyalways/3.jpg" alt="Exhibition view" loading="lazy" style="width:100%; border-radius: 4px;" />
      <img src="/images/exhibitions/behappyalways/4.jpg" alt="Exhibition view" loading="lazy" style="width:100%; border-radius: 4px;" />
      <img src="/images/exhibitions/behappyalways/5.jpg" alt="Exhibition view" loading="lazy" style="width:100%; border-radius: 4px;" />
    </div>
  </div>
</Base>
